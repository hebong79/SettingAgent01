{
  "name": "parkagent-setting",
  "version": "0.1.0",
  "description": "ParkAgent SettingAgent — 프리셋 셋업·주차면 ROI 확보·전역 슬롯 인덱스 매핑 (LLM 두뇌 + MCP 도구)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "e2e": "tsx src/tools/e2eSmoke.ts",
    "export:camerapos": "tsx src/tools/exportCamerapos.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@parkagent/types": "*",
    "fastify": "^5.2.0",
    "openai": "^4.77.0",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
